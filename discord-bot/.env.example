DISCORD_TOKEN=
DISCORD_GUILD_ID=
DISCORD_CHANNEL_ID=
WHISPER_URL=http://localhost:9000
WHISPER_MODEL=base           # tiny | base | small | medium | large | large-v3
WHISPER_LANGUAGE=de          # blank = auto-detect | e.g. en, de, fr, nl ...
WHISPER_TASK=transcribe      # transcribe (keep language) | translate (to English)
WHISPER_INITIAL_PROMPT=      # optional: prime Whisper with expected words, e.g. "Scribe write down. Scribe stopp. Scribe new Page."
WHISPER_TIMEOUT_MS=30000     # abort Whisper request after this many milliseconds (default: 30000)
WHISPER_MIN_AUDIO_MS=500     # ignore audio clips shorter than this (default: 500) — filters brief mic blips
WHISPER_HALLUCINATION_FILTER=Vielen Dank  # pipe-separated phrases Whisper hallucinates on silence, e.g. "Vielen Dank|Ja, danke|Thanks for watching"
FOUNDRY_URL=http://localhost:30000
FOUNDRY_USER=
FOUNDRY_PASS=
FOUNDRY_FOLDER_NAME=Session Transcripts
FOUNDRY_PAGE_NAME=Transcript

# Voice command settings
# The bot starts PAUSED (console-only). Speak the trigger phrases to control recording.
# Example: "Scribe write down" → starts writing to Foundry
BOT_NAME=Scribe
BOT_COMMAND_START=write down
BOT_COMMAND_PAUSE=stop it