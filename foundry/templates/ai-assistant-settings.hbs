<form style="max-height:60vh;overflow-y:auto;box-sizing:border-box">
  <div style="display:flex;align-items:center;gap:.75rem;margin-bottom:1.25rem;padding:.75rem">
    <input type="checkbox" id="ai-enabled" name="enabled" {{#if enabled}}checked{{/if}}
      style="width:1.1em;height:1.1em;cursor:pointer">
    <label for="ai-enabled" style="font-weight:bold;margin:0;cursor:pointer">Enable AI Assistant</label>
  </div>

  <fieldset style="margin:5px 0px;">
    <legend>AI Tool</legend>

    <div class="form-group">
      <label for="ai-provider">AI Provider:</label>
      <div class="form-fields">
        <select id="ai-provider" name="aiProvider" data-dtype="String" style="width:100%">
          <option value="claude" {{#if (eq aiProvider "claude")}}selected{{/if}}>
            Claude (Anthropic API)
          </option>
          <option value="local-ai" {{#if (eq aiProvider "local-ai")}}selected{{/if}}>
            Local AI
          </option>
        </select>
      </div>
      <p class="notes hint">Choose your AI inference provider. Switch anytime without losing settings.</p>
    </div>

    <div id="claude-section" style="display:{{#if isClaudeProvider}}block{{else}}none{{/if}}">
      <div class="form-group">
        <label>Claude API Key:</label>
        <div class="form-fields">
          <input type="password" id="ai-api-key" name="claudeApiKey" value="{{claudeApiKey}}"
            placeholder="sk-ant-…" data-dtype="String" style="font-family:monospace">
        </div>
        <p class="notes hint"><i class="fas fa-key"></i>
          Your Anthropic API key. Required to use Claude.
        </p>
      </div>
      <div class="form-group">
        <label>Model:</label>
        <div class="form-fields">
          <select id="claude-model" name="claudeModel" data-dtype="String" style="width:100%">
            {{#each claudeModels}}
              <option value="{{this}}" {{#if (eq ../claudeModel this)}}selected{{/if}}>{{this}}</option>
            {{/each}}
          </select>
        </div>
      </div>
    </div>

    <div id="local-ai-section" style="display:{{#if isLocalAiProvider}}block{{else}}none{{/if}}">
      <div class="form-group">
        <label>Local AI Server URL:</label>
        <div class="form-fields">
          <input type="text" id="ai-local-url" name="localAiUrl" value="{{localAiUrl}}"
            placeholder="{{defaultLocalAiUrl}}" data-dtype="String" style="font-family:monospace">
        </div>
        <p class="notes hint">Base URL of your LocalAI or Ollama server.</p>
      </div>
      <div class="form-group" style="margin-top:.75rem">
        <label>Active Model:</label>
        <div class="form-fields">
          <select id="local-model" name="localModel" data-dtype="String" style="width:100%">
            {{#each installedLocalModels}}
              <option value="{{this}}" {{#if (eq ../localModel this)}}selected{{/if}}>{{this}}</option>
            {{/each}}
          </select>
        </div>
        {{#unless localAiReachable}}
        <p class="notes hint" style="color:var(--color-level-warning,#e6ac00)">
          <i class="fas fa-triangle-exclamation"></i> Server not reachable — check your URL above.
        </p>
        {{/unless}}
        <p class="notes hint">
          Model currently used for inference.
          <a href="{{localAiModelsUrl}}" target="_blank"><i class="fas fa-download"></i> Install or manage models</a>
          — then click Refresh.
        </p>
      </div>

      <div class="form-group">
        <div class="form-fields">
          <button type="button" data-action="refreshModels" style="width:100%">
            <i class="fas fa-rotate"></i> Refresh Model List
          </button>
        </div>
      </div>
    </div>


  </fieldset>

  <fieldset style="margin:5px 0px;">
    <legend>Session</legend>
    <div class="form-group">
      <label>Context Size:</label>
      <div class="form-fields">
        <input type="number" id="ai-context-size" name="sessionHistoryMessages" value="{{sessionHistoryMessages}}"
          min="1" max="200" data-dtype="Number">
      </div>
      <p class="notes hint">How many recent session messages to include in AI context. The session summary journal is stored automatically as <code>AI-Summary</code> and is not configurable.</p>
    </div>
  </fieldset>

  <fieldset style="margin:5px 0px;">
    <legend>Adventure</legend>
    <div class="form-group">
      <div class="form-fields">
        <button type="button" data-action="openLoreWizard" style="width:100%">
          <i class="fas fa-wand-magic-sparkles"></i> Adventure Setup
        </button>
      </div>
    </div>
  </fieldset>

  <div style="display:flex;justify-content:flex-end;margin-top:1.25rem">
    <button type="button" data-action="save" style="min-width:80px">
      <i class="fas fa-save"></i> Save
    </button>
  </div>
</form>