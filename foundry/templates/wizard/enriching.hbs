<div class="beavers-ai-assistant lore-wizard standard-form">

  {{#if phaseTitle}}<p class="lw-phase-title">{{phaseTitle}}</p>{{/if}}

  {{!-- Header --}}
  <p class="lw-intro" style="margin-top:0">
    {{#if enrichment.isComplete}}
      <i class="fas fa-circle-check" style="color:var(--color-level-success,#28a745)"></i>
      Map enrichment complete
    {{else if enrichment.isRunning}}
      <i class="fas fa-spinner fa-spin"></i>
      Enriching scene…
    {{else}}
      Scene {{enrichment.sceneIdx}} of {{enrichment.totalScenes}} —
      <strong>{{enrichment.sceneName}}</strong>
      {{#if enrichment.chapterName}}
        <span style="opacity:.65;font-size:.9em">({{enrichment.chapterName}})</span>
      {{/if}}
    {{/if}}
  </p>

  {{!-- Error banner --}}
  {{#if enrichment.error}}
  <div class="lw-alert lw-alert--error" style="margin-bottom:.75rem">
    <i class="fas fa-circle-exclamation"></i> {{enrichment.error}}
  </div>
  {{/if}}

  {{!-- PRE_SCENE --}}
  {{#if enrichment.isPreScene}}

    {{#if enrichment.hasConnections}}
    <div class="lw-alert lw-alert--info" style="margin-bottom:.75rem">
      <i class="fas fa-circle-info"></i> Map connections already exist for this scene.
    </div>
    {{/if}}

    {{!-- Image candidates --}}
    {{#if enrichment.images}}
    <p style="font-size:.875em;margin:.25rem 0 .5rem">Select a map image:</p>
    <div class="lw-image-grid">
      {{#each enrichment.images}}
      <label class="lw-image-option">
        <input type="radio" name="enrichment-image" value="{{url}}"
               {{#if (eq url ../enrichment.selectedImageUrl)}}checked{{/if}}>
        <img src="{{url}}" class="lw-image-thumb" alt="{{name}}" loading="lazy"
             title="{{name}}">
        <span class="lw-image-name">{{name}}</span>
      </label>
      {{/each}}
    </div>
    {{else}}
    <p style="font-size:.875em;opacity:.75">No candidate images found for this chapter.</p>
    {{/if}}

    {{!-- Buttons — split by whether connections already exist --}}
    {{#if enrichment.hasConnections}}
    <div class="lw-nav" style="gap:.5rem;flex-wrap:wrap">
      <button type="button" data-action="enrichReplaceScene"
              style="flex:1" {{#unless enrichment.hasSelectedImage}}disabled{{/unless}}>
        <i class="fas fa-rotate"></i> Replace connections
      </button>
      <button type="button" data-action="enrichAddScene"
              {{#unless enrichment.hasSelectedImage}}disabled{{/unless}}>
        <i class="fas fa-plus"></i> Add to existing
      </button>
      <button type="button" data-action="enrichSkipScene">Skip — keep current</button>
      <button type="button" data-action="stopEnrichment">Stop enrichment</button>
    </div>
    {{else}}
    <div class="lw-nav" style="gap:.5rem">
      <button type="button" data-action="enrichReplaceScene"
              style="flex:1" {{#unless enrichment.hasSelectedImage}}disabled{{/unless}}>
        <i class="fas fa-map"></i> Use selected image
      </button>
      <button type="button" data-action="enrichSkipScene">Skip this scene</button>
      <button type="button" data-action="stopEnrichment">Stop enrichment</button>
    </div>
    {{/if}}

  {{/if}}

  {{!-- RUNNING: live log --}}
  {{#if enrichment.isRunning}}
  <div id="enrichment-log"
       style="font-family:monospace;font-size:.85em;padding:.5rem .75rem;
              background:rgba(0,0,0,0.1);color:#111;
              border:1px solid var(--color-border-light-primary,#ccc);
              border-radius:4px;min-height:4rem;max-height:12rem;overflow-y:auto">
    {{#each enrichment.log}}
    <div>{{this}}</div>
    {{/each}}
  </div>
  {{/if}}

  {{!-- COMPLETE --}}
  {{#if enrichment.isComplete}}
  <p>
    {{enrichment.enrichedCount}}
    {{#if (eq enrichment.enrichedCount 1)}}scene{{else}}scenes{{/if}}
    enriched.
  </p>
  <div class="lw-nav">
    <button type="button" data-action="finishEnrichment" style="flex:1">
      <i class="fas fa-circle-check"></i> Finish
    </button>
  </div>
  {{/if}}

</div>