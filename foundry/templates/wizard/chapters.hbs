<div class="beavers-ai-assistant lore-wizard standard-form">

  <p style="margin-top:0">
    Confirm chapters before indexing. Drag to reorder, set role or skip any you want to exclude.
  </p>

  <div class="lw-chapter-list">
    {{#each chapters}}
    <div draggable="true" data-chapter-id="{{id}}" class="lw-chapter-row">

      <i class="fas fa-grip-vertical lw-chapter-grip"></i>

      <div class="lw-chapter-name">
        {{#if (eq sourceType "folder")}}<i class="fas fa-folder lw-icon-muted"></i>{{/if}}
        {{#if (eq sourceType "journal")}}<i class="fas fa-book lw-icon-muted"></i>{{/if}}
        {{#if (eq sourceType "header")}}<i class="fas fa-heading lw-icon-muted"></i>{{/if}}
        {{name}}
        <span class="lw-tokens">~{{tokens}} tokens</span>
      </div>

      <div class="lw-role-group">
        {{#if showOverviewOption}}
        <label class="lw-role-label">
          <input type="radio" name="chapter-role-{{id}}" value="overview" {{#if roleIsOverview}}checked{{/if}}>
          Overview
        </label>
        {{/if}}
        <label class="lw-role-label">
          <input type="radio" name="chapter-role-{{id}}" value="chapter" {{#if roleIsChapter}}checked{{/if}}>
          Chapter
        </label>
        <label class="lw-role-label">
          <input type="radio" name="chapter-role-{{id}}" value="skip" {{#if roleIsSkip}}checked{{/if}}>
          Skip
        </label>
      </div>

    </div>
    {{/each}}
  </div>

  <div class="lw-nav lw-nav--between">
    <button type="button" data-action="backToLocation">
      <i class="fas fa-arrow-left"></i> Back
    </button>
    <button type="button" data-action="confirmChapters">
      Continue <i class="fas fa-arrow-right"></i>
    </button>
  </div>

</div>