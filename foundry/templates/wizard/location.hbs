<div class="beavers-ai-assistant lore-wizard standard-form">

  <p style="margin-top:0">
    Select the folder or journal that contains your adventure content.
    The wizard will analyse its structure and build a hierarchical lore index.
  </p>

  <div class="form-group">
    <label for="wizard-location">Adventure Content:</label>
    <div class="form-fields">
      <select id="wizard-location" style="width:100%">
        <option value="">(select…)</option>
        {{#each locations}}
          <option value="{{id}}" data-type="{{type}}">
            {{#if (eq type "folder")}}[Folder]{{else}}[Journal]{{/if}} {{name}}
          </option>
        {{/each}}
      </select>
    </div>
  </div>

  <div id="wizard-index-status"></div>

  <div class="lw-nav lw-nav--end">
    <button type="button" data-action="continueFromLocation">
      Continue <i class="fas fa-arrow-right"></i>
    </button>
  </div>

</div>