<div class="beavers-ai-assistant lore-wizard standard-form">

  {{#if hasAnyLoreIndex}}
  <div class="lw-alert lw-alert--success" style="margin-bottom:.75rem">
    <i class="fas fa-circle-check"></i> A lore index exists.
  </div>
  {{/if}}

  <p style="margin-top:0">
    Select the adventure content to index.
  </p>

  {{!-- Render parser form fields dynamically --}}
  {{#each parserFields}}
  <div class="form-group">
    <label for="parser-field-{{this.key}}">{{this.label}}:</label>
    <div class="form-fields">
      {{#if (eq this.type "select")}}
      <select id="parser-field-{{this.key}}" name="parser-field-{{this.key}}" style="width:100%">
        <option value="">{{#if this.placeholder}}{{this.placeholder}}{{else}}(select…){{/if}}</option>
        {{#each this.options}}
        <option value="{{this.value}}"
          {{#if (eq this.value (lookup ../../../parserFormValues ../key))}}selected{{/if}}>
          {{this.label}}
        </option>
        {{/each}}
      </select>
      {{else if (eq this.type "password")}}
      <input type="password" id="parser-field-{{this.key}}" name="parser-field-{{this.key}}"
             value="{{lookup ../parserFormValues this.key}}"
             placeholder="{{this.placeholder}}">
      {{else}}
      <input type="text" id="parser-field-{{this.key}}" name="parser-field-{{this.key}}"
             value="{{lookup ../parserFormValues this.key}}"
             placeholder="{{this.placeholder}}">
      {{/if}}
    </div>
  </div>
  {{/each}}

  {{!-- Per-selection status badge (updated by JS) --}}
  <div id="wizard-index-status"></div>

  <div class="lw-nav lw-nav--end" style="gap:.5rem;margin-top:.75rem">
    <button type="button" data-action="goToEnrichmentFromLocation"
            id="wizard-enrichment-btn"
            data-has-global-index="{{hasAnyLoreIndex}}"
            {{#unless hasAnyLoreIndex}}style="display:none"{{/unless}}>
      Map Enrichment <i class="fas fa-map"></i>
    </button>
    <button type="button" data-action="continueFromLocation"
            id="wizard-continue-btn" disabled>
      Continue <i class="fas fa-arrow-right"></i>
    </button>
  </div>

</div>